generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role

  doctor       Doctor?
  orders       MedicineOrder[]
  appointments Appointment[]   @relation("PatientAppointments")

  patientProfile PatientProfile?
  prescriptions  Prescription[]
}

model Doctor {
  id                  String   @id @default(uuid())
  name                String
  specialization      String
  experienceYears     Int      @default(0)
  qualification       String   @default("")
  bio                 String   @default("")
  consultationFee     Decimal  @default(0)
  isActive            Boolean  @default(true)
  availableDays       String[] @default([])
  availableHoursStart String   @default("09:00")
  availableHoursEnd   String   @default("17:00")
  userId              String   @unique

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  prescriptions Prescription[]
}

model Appointment {
  id               String            @id @default(uuid())
  patientId        String
  doctorId         String
  appointment_date DateTime
  appointment_time String
  status           AppointmentStatus
  symptoms         String
  notes            String?
  meetingLink      String?

  patient       User           @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]
  feedback      Feedback[]

  @@index([patientId])
  @@index([doctorId])
}

model Feedback {
  id            String @id @default(uuid())
  appointmentId String
  rating        Int
  comments      String

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model PatientProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  full_name         String
  phone             String?
  date_of_birth     DateTime?
  gender            String?
  address           String?
  emergency_contact String?
  medical_history   String?
  allergies         String?
  blood_group       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prescription {
  id            String  @id @default(uuid())
  appointmentId String
  doctorId      String
  patientId     String?

  instructions String

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor      Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  User   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model HealthSeminar {
  id              String   @id @default(uuid())
  title           String
  description     String
  speakerName     String?
  speakerTitle    String?
  eventDate       DateTime
  eventTime       String
  durationMinutes Int      @default(60)
  topicCategory   String
  meetingLink     String?
  maxAttendees    Int      @default(100)
  isActive        Boolean  @default(false)

  createdAt DateTime @default(now())
}

model Medicine {
  id                   String  @id @default(uuid())
  name                 String
  genericName          String
  category             String
  description          String
  price                Decimal // ✅ changed from Float
  stockQuantity        Int
  requiresPrescription Boolean @default(true)
  manufacturer         String
  isAvailable          Boolean @default(true)

  items OrderItem[]

  createdAt DateTime @default(now())
}

model MedicineOrder {
  id              String      @id @default(uuid())
  patientId       String
  phoneNumber     String
  deliveryAddress String
  totalAmount     Decimal
  status          OrderStatus @default(PENDING)

  patient User        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  createdAt DateTime @default(now())

  @@index([patientId])
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  medicineId String
  quantity   Int
  price      Decimal

  order    MedicineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicine Medicine      @relation(fields: [medicineId], references: [id])

  @@index([orderId])
  @@index([medicineId])
}
